SELECT
    Imprumuturi.nume_client AS 'Client',
    Carti.titlu AS 'Titlu Carte',
    Autori.nume AS 'Autor'
FROM Imprumuturi
JOIN Carti ON Imprumuturi.carte_id = Carti.carte_id
JOIN Autori ON Carti.autor_id = Autori.autor_id;
