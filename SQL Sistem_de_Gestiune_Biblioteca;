USE Sistem_de_Gestiune_Biblioteca;

CREATE TABLE Autori(
    autor_id INT AUTO_INCREMENT PRIMARY KEY,
    nume VARCHAR(20) NOT NULL,
    tara_origine VARCHAR(50)
);
        SELECT * FROM Autori;

INSERT INTO Autori (nume, tara_origine)
  VALUES ('Stephen King', 'USA'),
         ('George Orwell', 'India'),
         ('Jane Austen', 'USA'),
         ('Mark Twain', 'USA'),
         ('Charles Dickens', 'England');

CREATE TABLE Carti(
        carte_id INT AUTO_INCREMENT PRIMARY KEY,
        titlu VARCHAR(50) NOT NULL,
        an_publicatie INT,
        autor_id INT,
        FOREIGN KEY (autor_id) REFERENCES Autori(autor_id)
);
        SELECT * FROM Carti;

INSERT INTO Carti (titlu, an_publicatie, autor_id)
VALUES
('The Shining', 1977,1),
('1984', 1948,2),
('Pride and Prejudice', 1813,3),
('Is He Dead?',2007,4),
('Oliver Twist',1838,5);

SELECT Carti.titlu, Autori.nume
From Carti
JOIN Autori ON Carti.autor_id = Autori.autor_id;

CREATE TABLE Imprumuturi(
    id_imprumut INT AUTO_INCREMENT PRIMARY KEY,
    carte_id INT,
    FOREIGN KEY (carte_id) REFERENCES Carti(carte_id),
    data_imprumut DATE,
    data_scadere DATE,
    nume_client VARCHAR(25)
);
SELECT * FROM Imprumuturi;

